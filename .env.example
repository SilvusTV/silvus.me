NODE_ENV=development
PORT=3333
HOST=0.0.0.0
APP_KEY=replace-with-secure-app-key
LOG_LEVEL=info

# PostgreSQL (Docker / compose)
POSTGRES_HOST=127.0.0.1
POSTGRES_PORT=5432
POSTGRES_DB=silvus_me
POSTGRES_USER=adonis
POSTGRES_PASSWORD=adonis

# AdonisJS (Lucid)
DB_CONNECTION=pg
DB_HOST=127.0.0.1
DB_PORT=5432
DB_USER=adonis
DB_PASSWORD=adonis
DB_DATABASE=silvus_me

# URL de connexion complète (utile selon la config choisie)
DATABASE_URL=postgresql://adonis:adonis@127.0.0.1:5432/silvus_me

RESEND_API_KEY=re_xxx
RESEND_FROM=no-reply@silvus.me
RESEND_TO=hello@silvus.me
