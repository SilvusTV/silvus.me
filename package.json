{
  "name": "silvus-me",
  "version": "0.1.1",
  "private": true,
  "type": "module",
  "license": "UNLICENSED",
  "engines": {
    "node": ">=24.0.0"
  },
  "scripts": {
    "dev": "node ace.js serve --hmr",
    "build": "node ace.js build",
    "deploy": "npm run build -- --ignore-ts-errors && node -e \"require('fs').copyFileSync('.env', 'build/.env')\" && cd build && npm i --omit=dev && node ace migration:run --force",
    "start": "node build/server.js",
    "prod": "npm run build && npm run start",
    "migration:run": "node ace.js migration:run",
    "migration:rollback": "node ace.js migration:rollback",
    "lint": "echo \"Configure eslint for Adonis + React\"",
    "typecheck": "tsc --noEmit && tsc --noEmit --project tsconfig.inertia.json"
  },
  "imports": {
    "#controllers/*": "./app/controllers/*.js",
    "#exceptions/*": "./app/exceptions/*.js",
    "#services/*": "./app/services/*.js",
    "#validators/*": "./app/validators/*.js",
    "#middleware/*": "./app/middleware/*.js",
    "#database/*": "./database/*.js",
    "#start/*": "./start/*.js",
    "#config/*": "./config/*.js"
  },
  "devDependencies": {
    "@adonisjs/assembler": "^8.4.0",
    "@adonisjs/tsconfig": "^2.0.0",
    "@poppinss/ts-exec": "^1.4.4",
    "@tailwindcss/postcss": "^4.1.15",
    "@types/node": "~25.6.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.4",
    "autoprefixer": "^10.4.21",
    "hot-hook": "^1.0.0",
    "pino-pretty": "^13.1.3",
    "postcss": "^8.5.6",
    "tailwindcss": "^4.1.15",
    "typescript": "~6.0.2",
    "vite": "^7.3.1"
  },
  "dependencies": {
    "@adonisjs/core": "^7.3.1",
    "@adonisjs/cors": "^3.0.0",
    "@adonisjs/inertia": "^4.2.0",
    "@adonisjs/lucid": "^22.4.2",
    "@adonisjs/static": "^2.0.1",
    "@adonisjs/vite": "^5.1.0",
    "@inertiajs/react": "^2.3.18",
    "@vinejs/vine": "^4.3.1",
    "edge.js": "^6.5.0",
    "luxon": "^3.7.2",
    "minio": "^8.0.7",
    "pg": "^8.16.3",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "reflect-metadata": "^0.2.2"
  },
  "hotHook": {
    "boundaries": [
      "./app/controllers/**/*.ts",
      "./app/middleware/*.ts"
    ]
  },
  "packageManager": "npm@11.4.2"
}
